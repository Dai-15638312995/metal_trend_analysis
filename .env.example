# Stooq 免费数据无需 API Key

# LLM API 配置
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=  # 可选，用于第三方 API（如 DeepSeek）
LLM_MODEL_NAME=gpt-4o  # 或其他模型

# 飞书推送配置 (可选)
# 留空则不启用飞书通知
# 获取方式: 飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=

# 钉钉推送配置 (可选)
# 留空则不启用钉钉通知
# 获取方式: 钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
DINGTALK_WEBHOOK_URL=

# Slack 推送配置 (可选)
# 留空则不启用 Slack 通知
# 获取方式: Slack -> Apps -> Create New App -> Incoming Webhooks -> Activate Incoming Webhooks
#          -> Add New Webhook to Workspace -> Copy Webhook URL
SLACK_WEBHOOK_URL=

# Telegram 推送配置 (可选)
# 留空则不启用 Telegram 通知
# 获取方式: 
#   1. 在 Telegram 中搜索 @BotFather，发送 /newbot 创建机器人并获取 Token
#   2. 向你的机器人发送一条消息，然后访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 Chat ID
#   3. 将 Token 和 Chat ID 分别填入下面（注意：Chat ID 是纯数字，如 123456789）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件推送配置 (可选)
# 留空则不启用邮件通知
# 注意：某些邮箱服务（如 Gmail、QQ 邮箱）需要使用授权码而非登录密码
# 授权码获取方式：邮箱设置 -> 账户安全 -> 开启 SMTP 服务 -> 生成授权码
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_TO=  # 多个收件人用逗号分隔

# 邮件 SMTP 配置 (可选，留空则自动检测)
# 如果自动检测失败，可以手动配置
EMAIL_SMTP_SERVER=  # 例如: smtp.gmail.com
EMAIL_SMTP_PORT=  # 例如: 587
